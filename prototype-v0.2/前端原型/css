body {
    font-family: 'Noto Sans SC', 'Poppins', sans-serif;
    margin: 0;
    padding: 0;
}

section {
    padding: 20px;
    margin: 20px;
    border: 1px solid #ccc;
    border - radius: 5px;
}

h2 {
    margin - top: 0;
}

input,
button {
    padding: 10px;
    margin: 5px;
}

.doll - card,
.crowdfund - card {
    border: 1px solid #ccc;
    border - radius: 5px;
    padding: 10px;
    margin: 10px;
    display: inline - block;
    width: 200px;
    text - align: center;
}

.doll - card img,
.crowdfund - card img {
    width: 100%;
    height: auto;
}